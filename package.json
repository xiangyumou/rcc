{
  "name": "claude-code-web-manager",
  "version": "1.0.0",
  "description": "Web-based manager for Claude Code sessions",
  "main": "dist/server/index.js",
  "scripts": {
    "postinstall": "node scripts/fix-pty-permissions.js",
    "build": "tsc",
    "dev": "ts-node src/server/index.ts",
    "start": "node dist/server/index.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "express": "^4.18.2",
    "node-pty": "^1.1.0",
    "uuid": "^9.0.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "keywords": [
