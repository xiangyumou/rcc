{
  "name": "claude-code-web-manager",
  "version": "1.0.0",
  "description": "Web-based manager for Claude Code sessions",
  "main": "dist/server/index.js",
  "scripts": {
    "postinstall": "node scripts/fix-pty-permissions.js",
    "build": "tsc",
    "dev": "ts-node src/main.ts",
    "start": "node dist/main.js",
    "clean": "rm -rf dist",
    "test": "vitest",
    "test:unit": "vitest --config vitest.config.ts tests/unit",
    "test:client": "vitest --config vitest.client.config.ts tests/unit/client",
    "test:integration": "vitest --config vitest.config.ts tests/integration",
    "test:e2e": "vitest --config vitest.config.ts tests/e2e",
    "test:all": "npm run test && npm run test:client",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "express": "^4.18.2",
    "node-pty": "^1.1.0",
    "uuid": "^9.0.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "jsdom": "^28.1.0",
    "msw": "^2.12.10",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "claude",
    "code",
    "terminal",
    "web",
    "manager"
  ],
  "author": "",
  "license": "MIT"
}
